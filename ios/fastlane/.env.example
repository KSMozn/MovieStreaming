# Copy to fastlane/.env and fill in — fastlane auto-loads fastlane/.env.
# Do NOT commit the filled-in .env or the .p8 key.

# App Store Connect API key:
#   App Store Connect → Users and Access → Integrations → App Store Connect API
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASC_KEY_PATH=./fastlane/AuthKey_XXXXXXXXXX.p8

# Apple Developer team id used to sign the archive. Optional — project.yml
# already bakes in the team (52GK9NV362); set this only to override it.
#   developer.apple.com → Membership
APPLE_TEAM_ID=52GK9NV362
