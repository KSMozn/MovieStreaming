# ReelSeek iOS — TestFlight + App Store lanes.
#
# Setup (values come from fastlane/.env — copy .env.example):
#   * App Store Connect API key (.p8): ASC_KEY_ID / ASC_ISSUER_ID / ASC_KEY_PATH
#   * APPLE_TEAM_ID for code signing (defaults to the team baked into project.yml)
#   * `xcodegen` and Xcode command-line tools must be on PATH
#
# The .xcodeproj is generated by XcodeGen and git-ignored, so every lane
# regenerates it from project.yml before archiving. The build number is derived
# from the latest TestFlight build so each upload is unique without hand-editing
# project.yml.

# Absolute paths keep the lanes independent of fastlane's working directory.
FASTLANE_DIR = File.expand_path(File.dirname(__FILE__))
PROJECT_DIR  = File.expand_path("..", FASTLANE_DIR)
XCODEPROJ    = File.join(PROJECT_DIR, "Reelseek.xcodeproj")
SCHEME       = "Reelseek"
APP_ID       = "com.khaledsamir.reelseek"

def signing_xcargs(build_number)
  args = ["-allowProvisioningUpdates"]
  team = ENV["APPLE_TEAM_ID"]
  args << "DEVELOPMENT_TEAM=#{team}" if team && !team.empty?
  args << "CURRENT_PROJECT_VERSION=#{build_number}"
  args.join(" ")
end

# Signing certs live in a CI keychain only when match is configured (CI).
# Locally, MATCH_GIT_URL is unset and the developer's own certificate in the
# login keychain is used with automatic signing.
def use_match?
  !ENV["MATCH_GIT_URL"].to_s.empty?
end

default_platform(:ios)

platform :ios do
  before_all do
    # No-op locally; on CI (CI=true) this creates a temporary keychain that
    # match unlocks and installs the distribution certificate into.
    setup_ci
    sh("cd \"#{PROJECT_DIR}\" && xcodegen generate")
  end

  private_lane :load_asc_api_key do
    app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_PATH"),
      in_house: false,
    )
  end

  # Installs the App Store distribution cert + provisioning profile from the
  # match git repo into the keychain (read-only — never regenerates them).
  # Skipped entirely when MATCH_GIT_URL is unset (local builds).
  private_lane :setup_signing do
    next unless use_match?
    match(
      type: "appstore",
      app_identifier: APP_ID,
      git_url: ENV.fetch("MATCH_GIT_URL"),
      readonly: true,
      api_key: lane_context[SharedValues::APP_STORE_CONNECT_API_KEY],
    )
  end

  desc "Build a signed App Store IPA (no upload)"
  lane :build do
    load_asc_api_key
    setup_signing
    # Sequential build number: one above the latest build already on
    # TestFlight for this marketing version. A fresh version starts at 1
    # (initial_build_number 0, then +1).
    version = get_version_number(xcodeproj: XCODEPROJ, target: SCHEME)
    build_number = latest_testflight_build_number(
      app_identifier: APP_ID,
      version: version,
      api_key: lane_context[SharedValues::APP_STORE_CONNECT_API_KEY],
      initial_build_number: 0,
    ) + 1
    UI.message("Using build number #{build_number} for #{version}")
    build_ios_app(
      project: XCODEPROJ,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      output_directory: File.join(PROJECT_DIR, "build/fastlane"),
      output_name: "Reelseek.ipa",
      clean: true,
      xcargs: signing_xcargs(build_number),
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    build
    upload_to_testflight(
      api_key: lane_context[SharedValues::APP_STORE_CONNECT_API_KEY],
      ipa: lane_context[SharedValues::IPA_OUTPUT_PATH],
      skip_waiting_for_build_processing: true,
    )
  end

  desc "Build and upload to the App Store (listing metadata left untouched)"
  lane :release do
    build
    upload_to_app_store(
      api_key: lane_context[SharedValues::APP_STORE_CONNECT_API_KEY],
      ipa: lane_context[SharedValues::IPA_OUTPUT_PATH],
      # Binary only. Flip these off once fastlane/metadata + screenshots are
      # populated (see docs/fastlane.md) so a release doesn't wipe the live
      # listing.
      skip_metadata: true,
      skip_screenshots: true,
      # Upload only; submit for review from App Store Connect after checking.
      submit_for_review: false,
      precheck_include_in_app_purchases: false,
    )
  end
end
