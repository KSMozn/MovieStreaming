# Copy to fastlane/.env and fill in — fastlane auto-loads fastlane/.env.
# Do NOT commit the filled-in .env or the service-account JSON.

# Google Play service-account key (JSON):
#   Play Console → Setup → API access → create/link a service account,
#   grant it release permissions, download the JSON key.
PLAY_JSON_KEY_PATH=./fastlane/play-service-account.json

# Optional: JDK 17 home. If unset, the lane auto-detects the Homebrew
# openjdk@17 or Android Studio's bundled JBR.
# ANDROID_JAVA_HOME=/Users/khaledsamir/homebrew/opt/openjdk@17
