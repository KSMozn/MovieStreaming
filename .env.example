# TMDb (https://www.themoviedb.org/settings/api) - REQUIRED
TMDB_API_KEY=

# Watchmode (https://api.watchmode.com/) - for streaming availability
WATCHMODE_API_KEY=

# Streaming Availability API (RapidAPI) - alternative; not used by default
STREAMING_AVAILABILITY_API_KEY=

# OMDb (https://www.omdbapi.com/) - for IMDb rating fallback
OMDB_API_KEY=

# Default country (ISO 3166-1 alpha-2)
DEFAULT_COUNTRY=EG

# Optional: PostgreSQL for caching/favorites/history (not required for MVP)
DATABASE_URL=
