# TMDb (https://www.themoviedb.org/settings/api) - REQUIRED
TMDB_API_KEY=

# Watchmode (https://api.watchmode.com/) - for streaming availability
WATCHMODE_API_KEY=

# Streaming Availability API (RapidAPI) - alternative; not used by default
STREAMING_AVAILABILITY_API_KEY=

# OMDb (https://www.omdbapi.com/) - for IMDb rating fallback
OMDB_API_KEY=

# Default country (ISO 3166-1 alpha-2)
DEFAULT_COUNTRY=EG

# Optional: PostgreSQL for caching/favorites/history (not required for MVP)
DATABASE_URL=

# --- SEO / discoverability ---
# Canonical public origin (defaults to https://reelseek.co if unset)
NEXT_PUBLIC_SITE_URL=https://reelseek.co
# Set to "false" ONLY on preview/staging deployments (blocks indexing + empties sitemap)
SEO_INDEXING_ENABLED=true
# Search-engine ownership verification (never commit real tokens)
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
# IndexNow (key served at /indexnow-key.txt; keyLocation optional override)
INDEXNOW_KEY=
INDEXNOW_KEY_LOCATION=
